---
export const prerender = false;

import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/page.layout.astro';
import OpenGraphMeta from '@/components/seo/opengraph-meta.astro';
import AlphabetNav from '@/components/bears/alphabet-nav.astro';
import BearCard from '@/components/bears/bear-card.astro';
import Pagination from '@/components/ui/pagination.astro';
import PageHeader from '@/components/ui/page-header.astro';
import Separator from '@/components/ui/separator.astro';
import SectionBand from '@/components/ui/section-band.astro';
import BearSectionNav from '@/components/bears/bear-section-nav.astro';
import EmptyState from '@/components/ui/empty-state.astro';
import { paginate } from '@/libs/pagination';
import { getActiveLetters, filterByLetter } from '@/libs/alphabet';
import { bearBrands, bearSpecies } from '@/content/config';
import {
  parseBearStatus,
  filterByStatus,
  filterBySpecies,
  filterByBrand,
  statusLabel,
  statusIntro,
  slugToLabel,
  buildBearsUrl,
  type BearStatus,
} from '@/libs/bear-groups';

// --- Parse query params ---
const url = new URL(Astro.request.url);
const status: BearStatus = parseBearStatus(url.searchParams.get('status'));
const speciesParam = url.searchParams.get('species') || undefined;
const brandParam = url.searchParams.get('brand') || undefined;
const letter = url.searchParams.get('letter')?.toUpperCase() || undefined;
const pageParam = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10));

// Validate species and brand against known enums
const validSpecies = bearSpecies.options.includes(speciesParam as any) ? speciesParam : undefined;
const validBrand = bearBrands.options.includes(brandParam as any) ? brandParam : undefined;

// --- Fetch and filter bears ---
let allBears = await getCollection('bears');

// --- Cascading filter logic ---
// For each dropdown, compute available options from bears filtered by the OTHER two filters.
// This ensures each dropdown only shows options that will produce results.

// Bears filtered by status only
const byStatus = filterByStatus(allBears, status);

// Bears filtered by status + species (used to compute brand options)
const byStatusAndSpecies = validSpecies ? filterBySpecies(byStatus, validSpecies) : byStatus;

// Bears filtered by status + brand (used to compute species options)
const byStatusAndBrand = validBrand ? filterByBrand(byStatus, validBrand) : byStatus;

// Bears filtered by species + brand but NOT status (used to compute status counts)
let bySpeciesAndBrand = allBears;
if (validSpecies) bySpeciesAndBrand = filterBySpecies(bySpeciesAndBrand, validSpecies);
if (validBrand) bySpeciesAndBrand = filterByBrand(bySpeciesAndBrand, validBrand);

// Compute dropdown options with counts
type FilterOption = { value: string; label: string; count: number };

// Status options — count from bears filtered by species + brand
const statusOptions: FilterOption[] = [
  { value: 'all', label: 'Any status', count: bySpeciesAndBrand.length },
  { value: 'looking', label: 'Looking for a home', count: bySpeciesAndBrand.filter(b => !b.data.rehomed).length },
  { value: 'found', label: 'Found their home', count: bySpeciesAndBrand.filter(b => !!b.data.rehomed).length },
].filter(o => o.value === 'all' || o.count > 0);

// Species options — count from bears filtered by status + brand
const speciesCounts = new Map<string, number>();
for (const b of byStatusAndBrand) {
  speciesCounts.set(b.data.species, (speciesCounts.get(b.data.species) || 0) + 1);
}
const speciesOptions: FilterOption[] = [...speciesCounts.entries()]
  .map(([value, count]) => ({ value, label: slugToLabel(value), count }))
  .sort((a, b) => a.label.localeCompare(b.label));

// Brand options — count from bears filtered by status + species
const brandCounts = new Map<string, number>();
for (const b of byStatusAndSpecies) {
  brandCounts.set(b.data.brand, (brandCounts.get(b.data.brand) || 0) + 1);
}
const brandOptions: FilterOption[] = [...brandCounts.entries()]
  .map(([value, count]) => ({ value, label: slugToLabel(value), count }))
  .sort((a, b) => a.label.localeCompare(b.label));

// --- Auto-select when only one real option exists ---
// If a dropdown has just "any" + one option, treat that option as selected
const effectiveStatus: BearStatus = statusOptions.length === 2 && status === 'all'
  ? statusOptions[1].value as BearStatus : status;
const effectiveSpecies = speciesOptions.length === 1 && !validSpecies
  ? speciesOptions[0].value : validSpecies;
const effectiveBrand = brandOptions.length === 1 && !validBrand
  ? brandOptions[0].value : validBrand;

// --- Apply all filters for the final result set ---
let bears = filterByStatus(allBears, effectiveStatus);
if (effectiveSpecies) bears = filterBySpecies(bears, effectiveSpecies);
if (effectiveBrand) bears = filterByBrand(bears, effectiveBrand);
if (validBrand) {
  bears = filterByBrand(bears, validBrand);
}

// Compute active letters from the filtered set (before letter filter)
const activeLetters = getActiveLetters(bears);

// Validate letter param
const validLetter = letter && activeLetters.includes(letter) ? letter : undefined;

// Filter by letter
if (validLetter) {
  bears = filterByLetter(bears, validLetter);
}

// Sort alphabetically by name
bears.sort((a, b) => a.data.name.localeCompare(b.data.name));

// --- Check if any filters are active ---
const hasActiveFilters = effectiveStatus !== 'all' || !!effectiveSpecies || !!effectiveBrand || !!validLetter;

// --- Params to preserve in pagination/alphabet links ---
const preserveParams: Record<string, string> = {};
if (effectiveStatus !== 'all') preserveParams.status = effectiveStatus;
if (effectiveSpecies) preserveParams.species = effectiveSpecies;
if (effectiveBrand) preserveParams.brand = effectiveBrand;
if (validLetter) preserveParams.letter = validLetter;

// 6. Paginate
const { paginatedItems: paginatedBears, currentPage, totalPages, totalItems: totalBears, prevUrl, nextUrl, paginationParams } = paginate({
  items: bears,
  page: pageParam,
  baseUrl: '/bears',
  params: preserveParams,
});

// --- SEO ---
const heading = statusLabel(effectiveStatus);
const pageTitle = validLetter
  ? `${heading} - ${validLetter}`
  : heading;
const description = `Browse ${totalBears} rescued bears at Amanda's Emporium — some still looking for a home, some already settled.`;
---

<PageLayout title={pageTitle} description={description}>
  <OpenGraphMeta
    slot="og-meta"
    title={`${pageTitle} | Amanda's Emporium`}
    description={description}
    url={Astro.url.href}
  />
  <Fragment slot="head-extra">
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
  </Fragment>

  <section class="bears-page">
    <PageHeader
      title={heading}
      intro={statusIntro(effectiveStatus)}
      count={totalBears}
      noun="bear"
    />

    <SectionBand>
      <BearSectionNav current="listing" />
    </SectionBand>

    <div class="bears-page__filters">
      <form class="bear-filters" action="/bears" method="get">
        <div class="bear-filters__controls">
          <select name="status" class="bear-filters__select" aria-label="Filter by status">
            {statusOptions.map((o) => (
              <option value={o.value} selected={effectiveStatus === o.value}>
                {`${o.label} (${o.count})`}
              </option>
            ))}
          </select>

          <select name="species" class="bear-filters__select" aria-label="Filter by species">
            <option value="" selected={!effectiveSpecies}>All species ({byStatusAndBrand.length})</option>
            {speciesOptions.map((o) => (
              <option value={o.value} selected={effectiveSpecies === o.value}>{o.label} ({o.count})</option>
            ))}
          </select>

          <select name="brand" class="bear-filters__select" aria-label="Filter by brand">
            <option value="" selected={!effectiveBrand}>All brands ({byStatusAndSpecies.length})</option>
            {brandOptions.map((o) => (
              <option value={o.value} selected={effectiveBrand === o.value}>{o.label} ({o.count})</option>
            ))}
          </select>

          {hasActiveFilters && (
            <a href="/bears" class="bear-filters__clear" data-umami-event="bear-filter-clear">Clear all</a>
          )}
        </div>
        <noscript><button type="submit" class="bear-filters__submit">Apply</button></noscript>
      </form>
    </div>

    <div class="bears-page__alphabet">
      <AlphabetNav
        activeLetters={activeLetters}
        currentLetter={validLetter}
        baseUrl="/bears"
        params={preserveParams}
      />
    </div>

    {paginatedBears.length > 0 ? (
      <ul class="bears-page__grid" role="list">
        {paginatedBears.map((bear, index) => (
          <li>
            <BearCard
              bear={bear}
              loading={index < 8 ? 'eager' : 'lazy'}
              subtitle={bear.data.tagline}
            />
          </li>
        ))}
      </ul>
    ) : (
      <EmptyState
        message="No bears match those filters. Try adjusting your selection, or clear the filters to see everyone."
        href="/bears"
        linkText="View all bears"
      />
    )}

    {totalPages > 1 && (
      <div class="bears-page__pagination">
        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          baseUrl="/bears"
          params={paginationParams}
        />
      </div>
    )}

  </section>
</PageLayout>

<script>
  function initBearFilters() {
    const form = document.querySelector('.bear-filters') as HTMLFormElement | null;
    if (!form) return;

    form.querySelectorAll('select').forEach((select) => {
      select.addEventListener('change', () => {
        const formData = new FormData(form);
        const params = new URLSearchParams();

        const status = formData.get('status') as string;
        if (status && status !== 'all') params.set('status', status);

        const species = formData.get('species') as string;
        if (species) params.set('species', species);

        const brand = formData.get('brand') as string;
        if (brand) params.set('brand', brand);

        // Don't preserve letter — let the server re-evaluate active letters
        const qs = params.toString();
        window.location.href = qs ? `/bears?${qs}` : '/bears';
      });
    });
  }

  initBearFilters();
  document.addEventListener('astro:after-swap', initBearFilters);
</script>

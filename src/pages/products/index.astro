---
export const prerender = false;

import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/page.layout.astro';
import FilterTabs from '@/components/ui/filter-tabs.astro';
import ProductCard from '@/components/products/product-card.astro';
import Pagination from '@/components/ui/pagination.astro';
import { ITEMS_PER_PAGE } from '@/libs/consts';
import { productCategories } from '@/content/config';

// --- Category labels ---
const categoryLabels: Record<string, string> = {
  'bags-and-cases': 'Bags & Cases',
  'baby-and-children': 'Baby & Children',
  'knitted-and-crocheted': 'Knitted & Crocheted',
  'home-and-gifts': 'Home & Gifts',
  'soaps': 'Soaps',
  'rescued-bears': 'Rescued Bears',
};

// --- Parse query params ---
const url = new URL(Astro.request.url);
const categoryParam = url.searchParams.get('category') || undefined;
const pageParam = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10));

// Validate category against the enum
const validCategories = productCategories.options;
const category = categoryParam && validCategories.includes(categoryParam as any)
  ? categoryParam
  : undefined;

// --- Fetch and filter products ---
let allProducts = (await getCollection('products')).filter(p => !p.data.hidden);

let products = category
  ? allProducts.filter(p => p.data.category === category)
  : allProducts;

// Sort alphabetically by name
products.sort((a, b) => a.data.name.localeCompare(b.data.name));

// Paginate
const totalProducts = products.length;
const totalPages = Math.max(1, Math.ceil(totalProducts / ITEMS_PER_PAGE));
const currentPage = Math.min(pageParam, totalPages);
const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
const paginatedProducts = products.slice(startIndex, startIndex + ITEMS_PER_PAGE);

// --- Build tab data ---
const tabs = [
  { label: 'All', value: 'all', href: '/products' },
  ...validCategories.map(cat => ({
    label: categoryLabels[cat] || cat,
    value: cat,
    href: `/products?category=${cat}`,
  })),
];

const activeTab = category || 'all';

// --- Params to preserve in pagination ---
const paginationParams: Record<string, string> = {};
if (category) paginationParams.category = category;

// --- SEO ---
const categoryTitle = category ? categoryLabels[category] : undefined;
const pageTitle = categoryTitle
  ? `${categoryTitle} | Products`
  : 'Products';
const description = 'Handmade bags, baby items, knitted goods, soaps, and more. All made by hand.';

const prevUrl = currentPage > 1
  ? `/products?${new URLSearchParams({ ...paginationParams, page: String(currentPage - 1) }).toString()}`
  : undefined;
const nextUrl = currentPage < totalPages
  ? `/products?${new URLSearchParams({ ...paginationParams, page: String(currentPage + 1) }).toString()}`
  : undefined;
---

<PageLayout title={pageTitle} description={description}>
  <Fragment slot="og-meta">
    <meta property="og:title" content={`${pageTitle} | Amanda's Emporium`} />
    <meta property="og:description" content={description} />
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
  </Fragment>

  <section class="products-page">
    <header class="products-page__header">
      <h1 class="products-page__title">What I Make</h1>
      <p class="products-page__intro">
        Everything here is made by hand. Have a browse and see what catches your eye.
      </p>
      <p class="products-page__count">
        {totalProducts} {totalProducts === 1 ? 'product' : 'products'}
      </p>
    </header>

    <div class="products-page__filters">
      <FilterTabs tabs={tabs} activeValue={activeTab} ariaLabel="Filter products" />
    </div>

    {paginatedProducts.length > 0 ? (
      <ul class="products-page__grid" role="list">
        {paginatedProducts.map((product, index) => (
          <li>
            <ProductCard
              product={product}
              loading={index < 8 ? 'eager' : 'lazy'}
            />
          </li>
        ))}
      </ul>
    ) : (
      <div class="products-page__empty">
        <p class="products-page__empty-text">
          Nothing in this category just now. I'm always making something new though. Check back soon or browse everything to see the full collection.
        </p>
        <a href="/products" class="products-page__empty-link">View all products</a>
      </div>
    )}

    {totalPages > 1 && (
      <div class="products-page__pagination">
        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          baseUrl="/products"
          params={paginationParams}
        />
      </div>
    )}
  </section>
</PageLayout>

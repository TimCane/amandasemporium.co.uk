---
export const prerender = false;
import AdminLayout from '@/layouts/admin.layout.astro';
import AdminForm from '@/components/admin/AdminForm';
import { locationFields } from '@/lib/admin/field-defs';

if (!import.meta.env.DEV) {
  return Astro.redirect('/404');
}
---

<AdminLayout title="New Location">
  <h1>New Location</h1>
  <AdminForm client:load collection="locations" fields={locationFields} enableGeocoding={true} />
</AdminLayout>

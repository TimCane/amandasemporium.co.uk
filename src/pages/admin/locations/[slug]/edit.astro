---
export const prerender = false;
import AdminLayout from '@/layouts/admin.layout.astro';
import AdminForm from '@/components/admin/AdminForm';
import { locationFields } from '@/lib/admin/field-defs';
import { getEntry } from '@/lib/admin/content-manager';

if (!import.meta.env.DEV) {
  return Astro.redirect('/404');
}

const { slug } = Astro.params;
const entry = await getEntry('locations', slug!);

if (!entry) {
  return Astro.redirect('/admin/locations');
}
---

<AdminLayout title={`Edit ${entry.frontmatter.name}`}>
  <h1>Edit Location: {entry.frontmatter.name}</h1>
  <AdminForm
    client:load
    collection="locations"
    fields={locationFields}
    initialData={entry.frontmatter}
    initialBody={entry.body}
    initialSlug={slug}
    isEdit={true}
    enableGeocoding={true}
  />
</AdminLayout>

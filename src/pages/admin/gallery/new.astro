---
export const prerender = false;
import AdminLayout from '@/layouts/admin.layout.astro';
import AdminForm from '@/components/admin/AdminForm';
import { galleryFields } from '@/lib/admin/field-defs';

if (!import.meta.env.DEV) {
  return Astro.redirect('/404');
}
---

<AdminLayout title="New Gallery Item">
  <h1>New Gallery Item</h1>
  <AdminForm client:load collection="gallery" fields={galleryFields} />
</AdminLayout>

---
export const prerender = false;
import AdminLayout from '@/layouts/admin.layout.astro';
import AdminForm from '@/components/admin/AdminForm';
import { productFields } from '@/lib/admin/field-defs';
import { getEntry } from '@/lib/admin/content-manager';

if (!import.meta.env.DEV) {
  return Astro.redirect('/404');
}

const { slug } = Astro.params;
const entry = await getEntry('products', slug!);

if (!entry) {
  return Astro.redirect('/admin/products');
}
---

<AdminLayout title={`Edit ${entry.frontmatter.name}`}>
  <h1>Edit Product: {entry.frontmatter.name}</h1>
  <AdminForm
    client:load
    collection="products"
    fields={productFields}
    initialData={entry.frontmatter}
    initialBody={entry.body}
    initialSlug={slug}
    isEdit={true}
    enableAI={true}
  />
</AdminLayout>

---
/**
 * Bear Map component — Leaflet map wrapper.
 *
 * Two variants:
 *   - "full"    – all bears, marker clustering, legend, 70vh height
 *   - "profile" – single bear journey, wandering path, 400px height
 *
 * Leaflet is loaded entirely client-side via <script>.
 * Bear data is serialised into a data attribute at build time.
 */

export interface BearMapData {
  name: string;
  slug: string;
  picture: string;
  status: 'rescued' | 'rehomed';
  rescued: { lat: number; lng: number; name: string; date: string };
  event?: { lat: number; lng: number; name: string };
  rehomed?: { lat: number; lng: number; name: string; date: string };
}

interface Props {
  variant: 'full' | 'profile';
  bears: BearMapData[];
}

const { variant, bears } = Astro.props;
const mapData = JSON.stringify(bears);
---

<div class="bear-map" data-variant={variant}>
  <a href="#after-bear-map" class="bear-map__skip-link">Skip map</a>

  {/* Screen-reader fallback */}
  <p class="bear-map__sr-only">
    {variant === 'full'
      ? `Map showing rescue and rehoming locations for ${bears.length} bears.`
      : `Map showing the journey of ${bears[0]?.name ?? 'a bear'}.`}
  </p>

  <p class="bear-map__sr-only">
    Use Tab to navigate between map markers. Press Enter or Space to open a marker popup. Use +/- to zoom, arrow keys to pan.
  </p>

  <div
    id="bear-map-container"
    class="bear-map__canvas"
    data-bears={mapData}
    data-variant={variant}
    role="application"
    aria-label={variant === 'full' ? 'Interactive bear map' : `Journey map for ${bears[0]?.name ?? 'bear'}`}
  ></div>

  {variant === 'full' && (
    <div class="bear-map__legend" role="group" aria-label="Map legend">
      <span class="bear-map__legend-title">Legend</span>
      <span class="bear-map__legend-item">
        <span class="bear-map__legend-swatch bear-map__legend-swatch--rescued"></span>
        Rescued
      </span>
      <span class="bear-map__legend-item">
        <span class="bear-map__legend-swatch bear-map__legend-swatch--event"></span>
        Event
      </span>
      <span class="bear-map__legend-item">
        <span class="bear-map__legend-swatch bear-map__legend-swatch--rehomed"></span>
        Rehomed
      </span>
    </div>
  )}

  {/* Decoration div — themes can use this for visual flair */}
  <div class="bear-map__decoration" aria-hidden="true"></div>
</div>
<span id="after-bear-map" tabindex="-1"></span>

<script>
  import '@/libs/bear-map-init';
</script>

<style>
  .bear-map {
    position: relative;
    width: 100%;
  }
  .bear-map__skip-link {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    z-index: 10;
  }
  .bear-map__skip-link:focus {
    position: relative;
    width: auto;
    height: auto;
    padding: 0.5rem 1rem;
    margin: 0;
    overflow: visible;
    clip: auto;
    white-space: normal;
    background: var(--color-primary, #333);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    display: inline-block;
  }
  .bear-map__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .bear-map__canvas {
    width: 100%;
    z-index: 1;
    border: 2px solid var(--color-accent);
    border-radius: 6px;
    box-shadow:
      0 0 0 6px var(--color-bg),
      0 0 0 8px var(--color-border),
      0 4px 16px rgba(61, 50, 41, 0.1);
    filter: sepia(0.08) saturate(0.9);
  }
  .bear-map__canvas[data-variant="full"] {
    height: 70vh;
    min-height: 400px;
  }
  .bear-map__canvas[data-variant="profile"] {
    height: 400px;
  }
  .bear-map__legend {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    flex-wrap: wrap;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    margin-top: 1.25rem;
    font-family: var(--font-body);
    color: var(--color-text);
    box-shadow: 0 2px 8px rgba(61, 50, 41, 0.06);
  }
  .bear-map__legend-title {
    font-family: var(--font-heading);
    color: var(--color-primary-dark);
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    font-weight: 600;
  }
  .bear-map__legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .bear-map__legend-swatch {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid #fff;
    border-color: var(--color-accent);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  }
  .bear-map__legend-swatch--rescued { background: var(--color-primary-dark); }
  .bear-map__legend-swatch--event   { background: var(--color-accent); }
  .bear-map__legend-swatch--rehomed { background: var(--color-secondary); }
  .bear-map__decoration {
    display: none;
  }

  /* Popup styles (injected into Leaflet popups) — global so they pierce shadow DOM */
  :global(.bear-map__popup) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 140px;
    font-size: 0.85rem;
  }
  :global(.bear-map__popup-name) {
    font-size: 1rem;
    font-weight: 700;
  }
  :global(.bear-map__popup-badge) {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    text-transform: capitalize;
    width: fit-content;
  }
  :global(.bear-map__popup-badge--rescued) {
    background: var(--color-primary-dark);
    color: var(--color-on-primary, #fff);
  }
  :global(.bear-map__popup-badge--rehomed) {
    background: var(--color-badge-found-bg, var(--color-secondary));
    color: var(--color-badge-found-text, #fff);
  }
  :global(.bear-map__popup-location) {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }
  :global(.bear-map__popup-link) {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
    margin-top: 0.25rem;
  }
  :global(.bear-map__popup-link:hover) {
    text-decoration: underline;
  }
  /* Remove default Leaflet marker class styling that could interfere */
  :global(.bear-map__marker) {
    background: none !important;
    border: none !important;
  }
</style>

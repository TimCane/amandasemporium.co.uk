---
import { Image } from 'astro:assets';

interface TimelineEntry {
  date: Date;
  type: 'rescued' | 'rehomed';
  bearName: string;
  bearSlug: string;
  bearPicture: ImageMetadata;
  locationName: string;
}

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const monthYearFormatter = new Intl.DateTimeFormat('en-GB', {
  month: 'long',
  year: 'numeric',
});

// Group entries by year for navigation and visual grouping
const entriesByYear = new Map<number, TimelineEntry[]>();
for (const entry of entries) {
  const year = entry.date.getFullYear();
  if (!entriesByYear.has(year)) {
    entriesByYear.set(year, []);
  }
  entriesByYear.get(year)!.push(entry);
}

const years = [...entriesByYear.keys()].sort((a, b) => b - a);
---

<div class="timeline">
  <div class="timeline__decoration timeline__decoration--top" aria-hidden="true"></div>

  <nav class="timeline__year-nav" aria-label="Jump to year">
    <span class="timeline__year-nav-label">Jump to year:</span>
    <div class="timeline__year-nav-links">
      {years.map(year => (
        <a href={`#year-${year}`} class="timeline__year-nav-link">{year}</a>
      ))}
    </div>
  </nav>

  <ol class="timeline__list" role="list">
    {years.map((year, yearIndex) => (
      <>
        <li class="timeline__year-marker" role="presentation">
          <div class="timeline__year-marker-line" aria-hidden="true"></div>
          <span class="timeline__year-marker-label" id={`year-${year}`}>{year}</span>
          <div class="timeline__year-marker-line" aria-hidden="true"></div>
        </li>
        {entriesByYear.get(year)!.map((entry, entryIndex) => {
          const isEven = (yearIndex + entryIndex) % 2 === 0;
          return (
            <li class={`timeline__entry timeline__entry--${entry.type} ${isEven ? 'timeline__entry--left' : 'timeline__entry--right'}`}>
              <div class="timeline__connector" aria-hidden="true">
                <div class="timeline__line"></div>
                <div class={`timeline__marker timeline__marker--${entry.type}`}></div>
                <div class="timeline__line"></div>
              </div>

              <div class="timeline__date">
                <time datetime={entry.date.toISOString().split('T')[0]}>
                  {dateFormatter.format(entry.date)}
                </time>
              </div>

              <a href={`/bears/${entry.bearSlug}`} class="timeline__content">
                <span class="sr-only">{dateFormatter.format(entry.date)} — </span>
                <div class="timeline__image-wrapper">
                  <Image
                    src={entry.bearPicture}
                    alt={entry.bearName}
                    width={80}
                    height={80}
                    class="timeline__image"
                  />
                </div>
                <div class="timeline__details">
                  <h3 class="timeline__bear-name">{entry.bearName}</h3>
                  <span class={`timeline__badge timeline__badge--${entry.type}`}>
                    {entry.type === 'rescued' ? 'Rescued' : 'Rehomed'}
                  </span>
                  <span class="timeline__location">{entry.locationName}</span>
                </div>
                <div class="timeline__content-decoration" aria-hidden="true"></div>
              </a>
            </li>
          );
        })}
      </>
    ))}
  </ol>

  <div class="timeline__decoration timeline__decoration--bottom" aria-hidden="true"></div>
</div>

<style lang="scss">
  .timeline {
    position: relative;
    max-width: 56rem;
    margin: 0 auto;

    &__decoration {
      display: none;
    }

    &__year-nav {
      display: flex;
      align-items: center;
      gap: var(--spacing-ms);
      flex-wrap: wrap;
      margin-bottom: var(--spacing-lg);
      padding: var(--spacing-md);
      background: var(--color-bg-alt);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-card);
    }

    &__year-nav-label {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: var(--color-text-muted);
    }

    &__year-nav-links {
      display: flex;
      gap: var(--spacing-sm);
      flex-wrap: wrap;
    }

    &__year-nav-link {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: var(--color-primary);
      text-decoration: none;
      padding: var(--spacing-xs) var(--spacing-sm);
      border-bottom: 1px solid transparent;
      transition: border-color var(--transition-fast);

      &:hover {
        border-bottom-color: var(--color-primary);
      }
    }

    &__list {
      list-style: none;
      margin: 0;
      padding: 0;
      position: relative;

      &::before {
        content: '';
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        top: 0;
        bottom: 0;
        width: 1px;
        background: var(--color-accent);

        @media (max-width: 768px) {
          left: 1.5rem;
        }
      }
    }

    &__year-marker {
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
      padding: var(--section-pad-x) 0;
      position: relative;
      z-index: 1;

      @media (max-width: 768px) {
        padding-left: 3.5rem;
      }
    }

    &__year-marker-line {
      flex: 1;
      height: 1px;
      background: var(--color-accent);

      @media (max-width: 768px) {
        &:first-child { display: none; }
      }
    }

    &__year-marker-label {
      font-family: var(--font-heading);
      font-size: var(--text-lg);
      color: var(--color-primary-dark);
      font-weight: 700;
      background: var(--color-bg);
      padding: var(--spacing-xs) var(--spacing-ml);
      border: 1px solid var(--color-accent);
      border-radius: var(--radius-card);
      white-space: nowrap;
    }

    &__entry {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: var(--spacing-md);
      align-items: center;
      padding: var(--spacing-ms) 0;

      @media (max-width: 768px) {
        grid-template-columns: auto 1fr;
        gap: var(--spacing-ms);
      }

      &--left {
        .timeline__date { text-align: right; order: 1; }
        .timeline__connector { order: 2; }
        .timeline__content { order: 3; }

        @media (max-width: 768px) {
          .timeline__date { text-align: left; order: unset; }
          .timeline__connector { order: unset; }
          .timeline__content { order: unset; }
        }
      }

      &--right {
        .timeline__date { text-align: left; order: 3; }
        .timeline__connector { order: 2; }
        .timeline__content { order: 1; text-align: right; flex-direction: row-reverse; }

        @media (max-width: 768px) {
          .timeline__date { text-align: left; order: unset; }
          .timeline__connector { order: unset; }
          .timeline__content { order: unset; text-align: left; flex-direction: row; }
        }
      }
    }

    &__connector {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 1.5rem;

      @media (max-width: 768px) {
        width: 3rem;
        flex-shrink: 0;
      }
    }

    &__line {
      width: 1px;
      flex: 1;
      background: var(--color-border);
    }

    &__marker {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--color-accent);
      border: 2px solid var(--color-bg);
      box-shadow: 0 0 0 1px var(--color-accent);
      flex-shrink: 0;

      &--rehomed {
        background: var(--color-secondary);
        box-shadow: 0 0 0 1px var(--color-secondary);
      }
    }

    &__date {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: var(--color-text-muted);

      @media (max-width: 768px) {
        display: none;
      }
    }

    &__content {
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
      padding: var(--spacing-ms) var(--spacing-md);
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-card);
      text-decoration: none;
      color: inherit;
      transition: box-shadow var(--transition-fast);

      &:hover {
        box-shadow: var(--shadow-md);
      }
    }

    &__content-decoration {
      display: none;
    }

    &__image-wrapper {
      flex-shrink: 0;
    }

    &__image {
      width: 60px;
      height: 60px;
      border-radius: var(--radius-card);
      object-fit: cover;
    }

    &__details {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    &__bear-name {
      font-family: var(--font-heading);
      font-size: var(--text-base);
      color: var(--color-text);
      margin: 0;
      font-weight: 600;
    }

    &__badge {
      display: inline-block;
      font-family: var(--font-body);
      font-size: var(--text-xs);
      padding: 2px var(--spacing-sm);
      border-radius: var(--radius-card);
      font-weight: 600;
      width: fit-content;

      &--rescued {
        background: var(--color-badge-rescued-bg);
        color: var(--color-badge-rescued-text);
      }

      &--rehomed {
        background: var(--color-badge-rehomed-bg);
        color: var(--color-badge-rehomed-text);
      }
    }

    &__location {
      font-family: var(--font-body);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
    }
  }
</style>

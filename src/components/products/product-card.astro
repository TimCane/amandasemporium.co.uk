---
import { Image } from 'astro:assets';
import Card from '@/components/ui/card.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
  loading?: 'lazy' | 'eager';
}

const { product, loading = 'lazy' } = Astro.props;

import { productCategoryLabels } from '@/libs/labels';

const { name, price, category, photos } = product.data;
const slug = product.slug;

const categoryLabel = productCategoryLabels[category] || category;
---

<Card href={`/products/${slug}`} class="product-card">
  <div class="product-card__image-wrapper">
    <Image
      src={photos[0]}
      alt={name}
      width={300}
      height={300}
      loading={loading}
      class="product-card__image"
    />
    <div class="product-card__overlay" aria-hidden="true"></div>
  </div>
  <div class="product-card__body">
    <h3 class="product-card__name">{name}</h3>
    <span class="product-card__price">{price}</span>
    <span class="product-card__category">{categoryLabel}</span>
  </div>
  <div class="product-card__decoration-element"></div>
</Card>

<style lang="scss" is:global>
  .product-card {
    .card__inner { padding: 0; }

    &__image-wrapper {
      position: relative;
      overflow: hidden;
    }

    &__image {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }

    &:hover &__image {
      transform: scale(1.03);
    }

    &__overlay { display: none; }

    &__body {
      padding: 1rem 1.25rem;
    }

    &__name {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      color: var(--color-text);
      margin: 0 0 0.35rem;
      font-weight: 600;
    }

    &__price {
      display: block;
      font-family: var(--font-body);
      font-size: 1rem;
      color: var(--color-primary-dark);
      font-weight: 600;
      margin-bottom: 0.35rem;
    }

    &__category {
      display: inline-block;
      font-family: var(--font-body);
      font-size: 0.8rem;
      padding: 0.15rem 0.5rem;
      border-radius: 2px;
      margin-bottom: 0.25rem;
      background: var(--color-badge-found-bg);
      color: var(--color-badge-found-text);
    }

    &__decoration-element { display: none; }
  }
</style>

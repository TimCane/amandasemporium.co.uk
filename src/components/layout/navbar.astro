---
import TextLogo from './text-logo.astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/bears', label: 'Bears' },
  { href: '/products', label: 'Products' },
  { href: '/events', label: 'Events' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="navbar" aria-label="Main navigation">
  <div class="navbar__inner">
    <TextLogo />
    <ul class="navbar__links">
      {navLinks.map(link => (
        <li class="navbar__item">
          <a
            href={link.href}
            class:list={['navbar__link', { 'navbar__link--active': pathname.startsWith(link.href) }]}
            aria-current={pathname.startsWith(link.href) ? 'page' : undefined}
            data-umami-event="nav-click"
            data-umami-event-label={link.label}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <button
      class="navbar__hamburger"
      aria-expanded="false"
      aria-controls="navbar-menu"
      aria-label="Toggle navigation menu"
      data-umami-event="mobile-menu"
    >
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
    </button>
  </div>
  <div class="navbar__decoration" aria-hidden="true"></div>
  <div id="navbar-menu" class="navbar__mobile-menu navbar__mobile-menu--hidden">
    <ul class="navbar__mobile-links">
      {navLinks.map(link => (
        <li class="navbar__mobile-item">
          <a
            href={link.href}
            class:list={['navbar__mobile-link', { 'navbar__mobile-link--active': pathname.startsWith(link.href) }]}
            aria-current={pathname.startsWith(link.href) ? 'page' : undefined}
            data-umami-event="nav-click"
            data-umami-event-label={link.label}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  function initNavbar() {
    const hamburger = document.querySelector('.navbar__hamburger');
    const mobileMenu = document.getElementById('navbar-menu');

    hamburger?.addEventListener('click', () => {
      const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
      hamburger.setAttribute('aria-expanded', String(!isOpen));
      mobileMenu?.classList.toggle('navbar__mobile-menu--hidden');
    });
  }

  initNavbar();
  document.addEventListener('astro:after-swap', initNavbar);
</script>

<style lang="scss">
  .navbar {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-accent);
    padding: var(--spacing-ms) var(--section-pad-x);
    position: sticky;
    top: 0;
    z-index: 100;

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--spacing-lg);
      max-width: var(--page-width);
      margin-inline: auto;
    }

    &__links {
      display: flex;
      gap: var(--spacing-ml);
      list-style: none;
      margin: 0;
      padding: 0;

      @media (max-width: 768px) {
        display: none;
      }
    }

    &__item {
      list-style: none;
    }

    &__link {
      font-family: var(--font-body);
      color: var(--color-text);
      text-decoration: none;
      font-size: var(--text-sm);
      letter-spacing: var(--tracking-normal);
      padding: var(--spacing-xs) 0;
      position: relative;
      transition: color var(--transition-normal);
      white-space: nowrap;

      &::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--color-accent);
        transition: width var(--transition-normal);
      }

      &:hover {
        color: var(--color-primary);

        &::after {
          width: 100%;
        }
      }

      &--active {
        color: var(--color-primary-dark);
        font-weight: 600;

        &::after {
          width: 100%;
          background: var(--color-accent);
        }
      }
    }

    &__hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: var(--spacing-xs);

      @media (max-width: 768px) {
        display: flex;
      }
    }

    &__hamburger-line {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--color-text);
      transition: transform var(--transition-normal);
    }

    &__mobile-menu {
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      padding: var(--spacing-md);

      &--hidden {
        display: none;
      }
    }

    &__mobile-links {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
    }

    &__mobile-item {
      list-style: none;
    }

    &__mobile-link {
      font-family: var(--font-body);
      color: var(--color-text);
      text-decoration: none;
      padding: var(--spacing-xs) var(--spacing-sm);
      display: block;
      border-left: 3px solid transparent;
      transition: border-color var(--transition-fast);

      &:hover {
        color: var(--color-primary);
        border-left-color: var(--color-accent);
      }

      &--active {
        color: var(--color-primary-dark);
        border-left-color: var(--color-accent);
        font-weight: 600;
      }
    }
  }
</style>

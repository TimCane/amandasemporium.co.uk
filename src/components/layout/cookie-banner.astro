<div id="cookie-banner" class="cookie-banner cookie-banner--hidden" role="region" aria-label="Cookie notice">
  <p class="cookie-banner__text">
    This site uses cookie-free analytics. Map tiles load from OpenStreetMap's servers, which may log your IP address.
    <a href="/privacy" class="cookie-banner__link">Privacy Policy</a>
  </p>
  <button id="cookie-banner-dismiss" class="cookie-banner__dismiss">Got it</button>
</div>

<script>
  function initCookieBanner() {
    const banner = document.getElementById('cookie-banner');
    const dismiss = document.getElementById('cookie-banner-dismiss');

    if (!localStorage.getItem('ae-cookie-banner-dismissed')) {
      banner?.classList.remove('cookie-banner--hidden');
    }

    dismiss?.addEventListener('click', () => {
      localStorage.setItem('ae-cookie-banner-dismissed', 'true');
      banner?.classList.add('cookie-banner--hidden');
    });
  }

  initCookieBanner();
  document.addEventListener('astro:after-swap', initCookieBanner);
</script>

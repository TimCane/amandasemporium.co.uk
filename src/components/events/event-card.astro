---
import Card from '@/components/ui/card.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  event: CollectionEntry<'events'>;
  showCalendarButton?: boolean;
}

const { event, showCalendarButton = false } = Astro.props;

const { name, date, time, location, info, website } = event.data;
const slug = event.slug;

const dateFormatter = new Intl.DateTimeFormat('en-GB', { day: 'numeric' });
const monthFormatter = new Intl.DateTimeFormat('en-GB', { month: 'short' });
const yearFormatter = new Intl.DateTimeFormat('en-GB', { year: 'numeric' });

const day = dateFormatter.format(date);
const month = monthFormatter.format(date);
const year = yearFormatter.format(date);
---

<Card href={`/events/${slug}`} class="event-card">
  <div class="event-card__date">
    <span class="event-card__day">{day}</span>
    <span class="event-card__month">{month}</span>
    <span class="event-card__year">{year}</span>
  </div>
  <div class="event-card__body">
    <h3 class="event-card__name">{name}</h3>
    <div class="event-card__meta">
      {time && <span class="event-card__time">{time}</span>}
      <span class="event-card__location">{location.name}</span>
    </div>
    {info && <p class="event-card__info">{info}</p>}
    <div class="event-card__actions">
      {website && (
        <a
          href={website}
          class="event-card__website-link"
          target="_blank"
          rel="noopener"
          onclick="event.stopPropagation();"
        >
          Visit website
        </a>
      )}
      {showCalendarButton && (
        <a
          href={`/events/calendar/${slug}.ics`}
          class="event-card__calendar-btn"
          onclick="event.stopPropagation();"
        >
          Add to Calendar
        </a>
      )}
    </div>
  </div>
  <div class="event-card__decoration-element"></div>
</Card>

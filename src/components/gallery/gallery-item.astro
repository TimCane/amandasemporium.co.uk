---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'gallery'>;
  loading?: 'lazy' | 'eager';
}

const { item, loading = 'lazy' } = Astro.props;

let resolvedLink: string | undefined;
if (item.data.relatedBear) resolvedLink = `/bears/${item.data.relatedBear.slug}`;
else if (item.data.relatedProduct) resolvedLink = undefined;
else if (item.data.relatedEvent) resolvedLink = `/events`;

const Tag = resolvedLink ? 'a' : 'div';

import { galleryCategoryLabels } from '@/libs/labels';

const categoryLabel = item.data.category
  ? galleryCategoryLabels[item.data.category] || item.data.category
  : undefined;
---

<Tag href={resolvedLink} class:list={['gallery-item', { 'gallery-item--linked': !!resolvedLink }]}>
  <div class="gallery-item__image-wrapper">
    <Image
      src={item.data.image}
      alt={item.data.caption || 'Gallery image'}
      width={400}
      loading={loading}
      class="gallery-item__image"
    />
  </div>
  <div class="gallery-item__caption">
    {item.data.caption && <p class="gallery-item__text">{item.data.caption}</p>}
    {categoryLabel && <span class="gallery-item__tag">{categoryLabel}</span>}
  </div>
</Tag>

<style lang="scss">
  .gallery-item {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    transition: box-shadow 0.3s ease;

    &--linked:hover {
      box-shadow: 0 4px 12px rgba(61, 50, 41, 0.15);
    }

    &__image-wrapper {
      position: relative;
      overflow: hidden;
    }

    &__image {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.3s ease;
    }

    &--linked:hover &__image {
      transform: scale(1.03);
    }

    &__caption {
      padding: 0.75rem 1rem;
    }

    &__text {
      font-family: var(--font-body);
      font-size: 0.95rem;
      color: var(--color-text);
      margin: 0 0 0.35rem;
      line-height: 1.4;
    }

    &__tag {
      display: inline-block;
      font-family: var(--font-body);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text-muted);
      background: var(--color-bg-alt);
      padding: 0.15rem 0.5rem;
      border-radius: 2px;
    }
  }
</style>

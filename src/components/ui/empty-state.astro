---
interface Props {
  message: string;
  href: string;
  linkText: string;
}

const { message, href, linkText } = Astro.props;
---

<div class="empty-state">
  <p class="empty-state__text">{message}</p>
  <a href={href} class="empty-state__link">{linkText}</a>
</div>

<style lang="scss">
  .empty-state {
    text-align: center;
    padding: 4rem 1rem;

    &__text {
      font-family: var(--font-body);
      color: var(--color-text-muted);
      font-size: 1.1rem;
      margin: 0 0 1rem;
    }

    &__link {
      font-family: var(--font-body);
      color: var(--color-primary);
      text-decoration: none;
      font-size: 0.95rem;
      border-bottom: 1px solid var(--color-accent);
      padding-bottom: 2px;
      transition: color 0.2s ease;

      &:hover {
        color: var(--color-primary-dark);
      }
    }
  }
</style>

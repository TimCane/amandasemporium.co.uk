---
// Component spec: Task 1.5 shared UI — Filter Tabs
interface Tab {
  label: string;
  value: string;
  href: string;
}

interface Props {
  tabs: Tab[];
  activeValue: string;
  ariaLabel?: string;
}

const { tabs, activeValue, ariaLabel = 'Filter bears' } = Astro.props;
---

<nav class="filter-tabs" aria-label={ariaLabel}>
  {tabs.map(tab => (
    <a
      href={tab.href}
      class:list={['filter-tabs__tab', { 'filter-tabs__tab--active': tab.value === activeValue }]}
      aria-current={tab.value === activeValue ? 'page' : undefined}
    >
      {tab.label}
    </a>
  ))}
</nav>

<style lang="scss">
  .filter-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.5rem;
    padding-bottom: 0.25rem;

    @media (max-width: 480px) {
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
    }

    &__tab {
      text-decoration: none;
      color: var(--color-text-muted);
      font-size: 0.9rem;
      padding: 0.5rem 0;
      border-bottom: 2px solid transparent;
      white-space: nowrap;
      transition: color 0.2s ease, border-color 0.2s ease;

      &:hover {
        color: var(--color-text);
      }

      &--active {
        color: var(--color-primary);
        border-bottom-color: var(--color-primary);
      }
    }
  }
</style>

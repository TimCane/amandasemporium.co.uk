---
interface Props {
  href: string;
  label: string;
  section: string;
}

const { href, label, section } = Astro.props;
---

<nav class="back-link" aria-label={`${section} navigation`}>
  <a href={href} class="back-link__anchor">
    <span class="back-link__arrow" aria-hidden="true">&larr;</span>
    {label}
  </a>
</nav>

<style lang="scss">
  .back-link {
    padding-top: 2rem;
    border-top: 1px solid var(--color-accent);

    &__anchor {
      font-family: var(--font-body);
      color: var(--color-primary);
      text-decoration: none;
      font-size: 0.95rem;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      transition: color 0.2s ease;

      &:hover {
        color: var(--color-primary-dark);
      }
    }

    &__arrow {
      font-size: 1.1rem;
    }
  }
</style>
